<!doctype html>
<html lang="tr">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Aday Takip Cockpit</title>
    <link rel="stylesheet" href="styles.css">
  </head>
  <body>
    <div class="app-shell">
      <aside class="sidebar">
        <div class="brand">
          <span class="brand-mark" aria-hidden="true">AT</span>
          <div>
            <strong>Aday Takip</strong>
            <small>İK karar cockpit</small>
          </div>
        </div>

        <button class="side-primary" id="addCandidateBtn" type="button">
          <span aria-hidden="true">＋</span>
          Yeni Aday
        </button>

        <nav class="side-nav" aria-label="Araçlar">
          <button class="side-link active" type="button" data-scroll-target="dashboardSection"><span>▦</span>Dashboard</button>
          <button class="side-link" type="button" data-scroll-target="candidateSection"><span>☰</span>Tüm Adaylar</button>
          <button class="side-link" type="button" data-modal="calendar"><span>□</span>Takvim</button>
          <button class="side-link" type="button" data-modal="kanban"><span>▥</span>Kanban</button>
          <button class="side-link" type="button" data-modal="questions"><span>?</span>Soru Bankası</button>
          <button class="side-link" type="button" data-modal="reports"><span>▤</span>Raporlar</button>
          <button class="side-link" type="button" data-modal="benchmark"><span>◇</span>Benchmark</button>
          <button class="side-link" type="button" data-modal="sourceQuality"><span>◌</span>Kaynak Kalitesi</button>
          <button class="side-link" type="button" data-modal="processDuration"><span>⏱</span>Süre Analizi</button>
          <button class="side-link" type="button" data-modal="cleanup"><span>✓</span>Veri Temizleme</button>
          <button class="side-link" type="button" data-modal="compare"><span>⇄</span>Karşılaştır</button>
          <button class="side-link" type="button" data-modal="requirements"><span>◎</span>Pozisyon Fit</button>
          <button class="side-link" type="button" data-modal="settings"><span>⚙</span>Ayarlar</button>
        </nav>

        <div class="side-card">
          <span>Kaynak</span>
          <strong id="sourceName">Excel</strong>
          <small id="sourceMeta">0 aday · 0 alan</small>
        </div>
      </aside>

      <main class="main">
        <header class="hero-bar">
          <div>
            <span class="eyebrow">Yönetici sunumuna hazır aday takip alanı</span>
            <h1>Aday Takip Cockpit</h1>
            <p>Dashboard, aday profili, görüşme notları, assessment, takvim, skor ve yönetici raporları tek ekranda.</p>
          </div>
          <div class="hero-actions">
            <input id="importFileInput" class="visually-hidden" type="file" accept=".csv,.txt">
            <button class="ghost-button" id="privacyBtn" type="button">Gizlilik: Kapalı</button>
            <select class="palette-select" id="paletteSelect" aria-label="Renk paleti">
              <option value="executive">Executive</option>
              <option value="ocean">Ocean</option>
              <option value="graphite">Graphite</option>
              <option value="berry">Berry</option>
            </select>
            <button class="ghost-button" id="importBtn" type="button">İçe Al</button>
            <button class="ghost-button" id="exportCsvBtn" type="button">CSV</button>
            <button class="ghost-button" id="exportExcelBtn" type="button">Excel</button>
            <button class="ghost-button" id="exportPptBtn" type="button">PPT</button>
            <button class="solid-button" id="printReportBtn" type="button">PDF / Yazdır</button>
          </div>
        </header>

        <section class="filter-bar" aria-label="Filtreler">
          <label class="search-box">
            <span aria-hidden="true">⌕</span>
            <input id="searchInput" type="search" placeholder="Aday, pozisyon, şehir, not, etiket ara">
          </label>
          <label><span>Durum</span><select id="statusFilter"></select></label>
          <label><span>Aşama</span><select id="stageFilter"></select></label>
          <label><span>Departman</span><select id="departmentFilter"></select></label>
          <label><span>Dönem</span><select id="periodFilter"></select></label>
        </section>

        <section id="dashboardSection" class="dashboard-section">
          <div class="metric-grid" id="metricGrid"></div>

          <div class="insight-grid">
            <section class="panel stage-panel">
              <div class="panel-head">
                <div><h2>Aday Hunisi</h2><p>Mülakat aşamalarına göre yoğunluk</p></div>
                <span id="stageTotal"></span>
              </div>
              <div class="bar-chart" id="stageChart"></div>
            </section>

            <section class="panel status-panel">
              <div class="panel-head"><div><h2>İşe Alım Durumu</h2><p>Filtrelenmiş adayların sonucu</p></div></div>
              <div class="donut-wrap">
                <div class="donut" id="statusDonut"></div>
                <div class="legend-list" id="statusLegend"></div>
              </div>
            </section>

            <section class="panel channel-panel">
              <div class="panel-head"><div><h2>Kanal Performansı</h2><p>Başvuru kaynakları</p></div></div>
              <div class="bar-chart compact" id="channelChart"></div>
            </section>

            <section class="panel week-panel">
              <div class="panel-head"><div><h2>Bu Hafta</h2><p>Takip ve görüşme planı</p></div></div>
              <div class="timeline-list" id="weekList"></div>
            </section>

            <section class="panel quality-panel">
              <div class="panel-head">
                <div><h2>Risk, Veri Kalitesi ve Aksiyonlar</h2><p>Eksik bilgi, geciken takip ve bütçe uyumu</p></div>
                <span id="qualityCount"></span>
              </div>
              <div class="alert-grid" id="qualityAlerts"></div>
            </section>
          </div>
        </section>

        <section id="candidateSection" class="candidate-section">
          <div class="section-head">
            <div>
              <span class="eyebrow">Detaylı liste</span>
              <h2>Tüm Adaylar</h2>
            </div>
            <div class="list-actions">
              <strong id="candidateCount">0 aday</strong>
              <select id="quickSort">
                <option value="Karar Skoru:desc">En yüksek karar skoru</option>
                <option value="Görüşme Tarihi:desc">En yeni görüşme</option>
                <option value="Başvuru Tarihi:desc">En yeni başvuru</option>
                <option value="Genel Değerlendirme Notu:desc">En yüksek değerlendirme</option>
                <option value="Teknik Puan (1-5):desc">En yüksek teknik puan</option>
                <option value="Ad Soyad:asc">Ada göre</option>
              </select>
            </div>
          </div>
          <div class="candidate-table-wrap">
            <table class="candidate-table">
              <thead id="candidateTableHead"></thead>
              <tbody id="candidateTableBody"></tbody>
            </table>
          </div>
        </section>
      </main>
    </div>

    <div class="modal-backdrop" id="modalBackdrop" hidden></div>

    <section class="modal modal-large" id="profileModal" aria-hidden="true">
      <div class="modal-head">
        <div><h2 id="profileTitle">Aday Profili</h2><p id="profileSubtitle"></p></div>
        <button class="icon-button" type="button" data-close-modal>×</button>
      </div>
      <div class="modal-body" id="profileBody"></div>
    </section>

    <section class="modal modal-large" id="formModal" aria-hidden="true">
      <form id="candidateForm">
        <div class="modal-head">
          <div><h2 id="formTitle">Yeni Aday</h2><p id="formSubtitle">Aday bilgileri, notlar ve assessment</p></div>
          <button class="icon-button" type="button" data-close-modal>×</button>
        </div>
        <div class="modal-body" id="formBody"></div>
        <div class="modal-foot">
          <button class="danger-button" id="deleteCandidateBtn" type="button">Sil</button>
          <div>
            <button class="ghost-button" type="button" data-close-modal>Vazgeç</button>
            <button class="solid-button" type="submit">Kaydet</button>
          </div>
        </div>
      </form>
    </section>

    <section class="modal modal-large" id="toolModal" aria-hidden="true">
      <div class="modal-head">
        <div><h2 id="toolTitle">Araç</h2><p id="toolSubtitle"></p></div>
        <button class="icon-button" type="button" data-close-modal>×</button>
      </div>
      <div class="modal-body" id="toolBody"></div>
    </section>

    <div class="toast" id="toast" role="status" aria-live="polite"></div>

    <script src="data.js"></script>
    <script src="app.js"></script>
  </body>
</html>
